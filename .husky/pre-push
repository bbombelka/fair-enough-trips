#!/bin/sh

# Husky passes arguments to pre-push:
# $1: Name of the remote to which the push is being done
# $2: URL to which the push is being done

# Initialize a flag to determine if we are pushing to master
pushing_master=0

# Read standard input for refs being pushed
# Format: <local ref> <local sha1> <remote ref> <remote sha1>
while read local_ref local_sha remote_ref remote_sha
do
    # Check if the remote ref being updated is master
    if [ "$remote_ref" = "refs/heads/master" ]; then
        pushing_master=1
        break
    fi
done

if [ $pushing_master -eq 1 ]; then
    echo "=================================================="
    echo "🚨 Pre-push hook: Pushing to master detected."
    echo "🧪 Running unit tests..."
    echo "=================================================="
    
    npm run test
    
    # Capture exit code of the test command
    TEST_RESULT=$?
    
    if [ $TEST_RESULT -ne 0 ]; then
        echo "=================================================="
        echo "❌ Tests failed! Push to master aborted."
        echo "=================================================="
        exit 1
    else
        echo "=================================================="
        echo "✅ Tests passed! Proceeding with push."
        echo "=================================================="
    fi
fi

exit 0
